DATABASE_URL="postgresql://homestock:homestock@localhost:5432/homestock_ai?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Hosted demo mode
# Keep these enabled for public/demo deployments until production auth exists.
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# Grocery commerce provider
# Local, QA, and hosted demo deployments should remain on mock mode.
GROCERY_PROVIDER="mock"

# Future Swiggy Builders Club / Instamart MCP placeholders.
# These are intentionally optional and unused in mock mode.
SWIGGY_BUILDERS_ENABLED="false"
SWIGGY_BUILDERS_CLIENT_ID=""
SWIGGY_BUILDERS_CLIENT_SECRET=""
SWIGGY_BUILDERS_REDIRECT_URI=""

# Auth.js (Phase 1 readiness — optional; only required for non-demo deployments).
# Demo deployments (DEMO_MODE=true) ignore these and continue to use actorId
# query switching. See docs/auth-readiness.md.
AUTH_SECRET=""
AUTH_URL=""
# Nodemailer SMTP connection string used by the magic-link email provider.
# Example: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER=""
EMAIL_FROM=""
